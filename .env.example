# NexusChat Environment Configuration
# Copy this to .env and update values

SECRET_KEY=your-very-secure-secret-key-change-this-immediately
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# Redis (required for WebSockets)
REDIS_URL=redis://redis:6379

# Optional: PostgreSQL (replace SQLite for production)
# DATABASE_URL=postgres://user:password@db:5432/nexuschat
